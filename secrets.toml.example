# Dev secrets — copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored; never commit it.
#
# These values are loaded as environment variables by the dev scripts.
# GREEN_DB_URL overrides auth.db_url from config.dev.toml at startup.

GREEN_DB_URL = "postgres://green:yourpassword@localhost/green"
GREEN_MQTT_PASSWORD = "your-mqtt-password"
