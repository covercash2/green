// Zellij layout for the "phone" dev session.
// Launch from the project root:
//   zellij --session phone --layout scripts/phone.kdl

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="claude" cwd="." focus=true {
        pane borderless=true command="claude"
    }
    tab name="watch" cwd="." {
        pane borderless=true command="nu" {
            args "scripts/dev.nu"
        }
    }
    tab name="logs" cwd="." {
        pane borderless=true command="tail" {
            args "-f" "logs.ndjson"
        }
    }
}
